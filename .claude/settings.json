{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "timeout": 180,
            "statusMessage": "Verifying (ruff + pytest)…",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/verify.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "cd \"${CLAUDE_PROJECT_DIR:-.}\" && bash .claude/hooks/guard.sh"
          }
        ]
      }
    ]
  }
}
