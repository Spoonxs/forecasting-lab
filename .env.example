# Copy to .env and fill in. .env is gitignored — never commit real keys.
# Market data reads are public; these are only needed for authenticated calls.

# Kalshi (trading / portfolio endpoints). Market data is public and needs neither.
# Generate an API key pair in the Kalshi dashboard; store the private key as a PEM file.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Quiver Quantitative (~$10/mo) for WSB sentiment, off-exchange short volume, etc.
QUIVER_API_KEY=

# SEC EDGAR requires a contact User-Agent (else 403). Free.
SEC_USER_AGENT=my-project you@example.com

# Free phone alerts (flab-alert). Set any, or none (falls back to inputs/alerts.log).
# RECOMMENDED — Discord webhook (no bot to host): Server Settings > Integrations >
# Webhooks > New Webhook > pick a channel > Copy Webhook URL. Then: flab-alert --test
DISCORD_WEBHOOK_URL=
# Alternative — Telegram: make a bot via @BotFather, then get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Override the project root if you run from outside the repo.
# FLAB_ROOT=
